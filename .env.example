# Database Connection
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>"

# Next Auth
AUTH_SECRET=""  # Generate with: openssl rand -base64 32

# GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI APIs (optional — needed for AI features)
GOOGLE_GENERATIVE_AI_API_KEY=""
GROQ_API_KEY=""

# GitHub Personal Access Token (optional — needed for Copilot integration)
GITHUB_TOKEN=""

# PTY Server URL (local development only)
# Leave BLANK for production — the unified server handles it on the same port.
# For local dev with separate PTY server: http://localhost:3001
NEXT_PUBLIC_PTY_URL="http://localhost:3001"
